<div class="flex-grow-1 overflow-auto p-4">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="mb-0" style="font-family: 'Space Grotesk', sans-serif; font-size: 22px; font-weight: 700;">Reports</h1>
    <div class="d-flex align-items-center gap-2">
      <%= link_to "< Prev", reports_path(month: (@month << 1).to_s), class: "btn btn-sm btn-outline-secondary" %>
      <span style="font-size: 14px; font-weight: 600;"><%= @month.strftime("%B %Y") %></span>
      <%= link_to "Next >", reports_path(month: (@month >> 1).to_s), class: "btn btn-sm btn-outline-secondary" %>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="p-3 rounded" style="background: #212529; border: 1px solid #343a40;">
        <div style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #868e96; margin-bottom: 4px;">
          Total Spending
        </div>
        <div style="font-size: 22px; font-weight: 700; color: #c92a2a;">
          <%= number_to_currency(@total_spending, unit: "$") %>
        </div>
      </div>
    </div>
  </div>

  <div style="background: #fff; border: 1px solid #dee2e6; border-radius: 6px; overflow: hidden;">
    <div class="fb-table__header">
      <div class="fb-table__cell fb-table__cell--header" style="flex: 2;">Group</div>
      <div class="fb-table__cell fb-table__cell--header fb-table__cell--payee">Category</div>
      <div class="fb-table__cell fb-table__cell--header fb-table__cell--outflow">Amount</div>
      <div class="fb-table__cell fb-table__cell--header" style="width: 120px; text-align: right; flex-shrink: 0;">% of Total</div>
    </div>
    <% @spending_by_category.each do |(group_name, cat_name), amount| %>
      <div class="fb-table__row">
        <div class="fb-table__cell" style="flex: 2; color: #868e96;"><%= group_name %></div>
        <div class="fb-table__cell fb-table__cell--payee"><%= cat_name %></div>
        <div class="fb-table__cell fb-table__cell--outflow fb-table__cell--money fb-table__cell--negative">
          <%= number_to_currency(amount, unit: "") %>
        </div>
        <div class="fb-table__cell fb-table__cell--money" style="width: 120px; text-align: right; flex-shrink: 0; font-size: 12px; color: #868e96;">
          <% pct = @total_spending > 0 ? (amount / @total_spending * 100).round(1) : 0 %>
          <%= pct %>%
          <div style="display: inline-block; width: 40px; height: 6px; background: #dee2e6; border-radius: 3px; vertical-align: middle; margin-left: 6px;">
            <div style="width: <%= pct %>%; height: 100%; background: #339af0; border-radius: 3px;"></div>
          </div>
        </div>
      </div>
    <% end %>
    <% if @spending_by_category.empty? %>
      <div class="p-4 text-center" style="color: #868e96;">No spending data for this month.</div>
    <% end %>
  </div>
</div>
