<div class="flex-grow-1 overflow-auto p-4">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="mb-0" style="font-family: 'Space Grotesk', sans-serif; font-size: 22px; font-weight: 700;">Budget</h1>
    <div class="d-flex align-items-center gap-2">
      <%= link_to "< Prev", budget_path(month: (@month << 1).to_s), class: "btn btn-sm btn-outline-secondary" %>
      <span style="font-size: 14px; font-weight: 600;"><%= @month.strftime("%B %Y") %></span>
      <%= link_to "Next >", budget_path(month: (@month >> 1).to_s), class: "btn btn-sm btn-outline-secondary" %>
    </div>
  </div>

  <div style="background: #fff; border: 1px solid #dee2e6; border-radius: 6px; overflow: hidden;">
    <div class="fb-table__header">
      <div class="fb-table__cell fb-table__cell--header" style="flex: 3;">Category</div>
      <div class="fb-table__cell fb-table__cell--header fb-table__cell--outflow">Assigned</div>
      <div class="fb-table__cell fb-table__cell--header fb-table__cell--outflow">Activity</div>
      <div class="fb-table__cell fb-table__cell--header fb-table__cell--outflow">Available</div>
    </div>

    <% @category_groups.each do |group| %>
      <div class="fb-table__row" style="background: #f1f3f5;">
        <div class="fb-table__cell" style="flex: 3; font-family: 'Space Grotesk', sans-serif; font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #339af0;">
          <%= group.name %>
        </div>
        <div class="fb-table__cell fb-table__cell--outflow"></div>
        <div class="fb-table__cell fb-table__cell--outflow"></div>
        <div class="fb-table__cell fb-table__cell--outflow"></div>
      </div>

      <% group.categories.where(archived: false).order(:display_order, :name).each do |cat| %>
        <% assigned = @allocations[cat.id] || 0 %>
        <% activity = @activity[cat.id] || 0 %>
        <% available = assigned - activity %>
        <div class="fb-table__row">
          <div class="fb-table__cell fb-table__cell--payee" style="flex: 3; padding-left: 20px;"><%= cat.name %></div>
          <div class="fb-table__cell fb-table__cell--outflow fb-table__cell--money">
            <%= number_to_currency(assigned, unit: "") %>
          </div>
          <div class="fb-table__cell fb-table__cell--outflow fb-table__cell--money <%= activity > 0 ? 'fb-table__cell--negative' : '' %>">
            <%= activity > 0 ? number_to_currency(activity, unit: "") : "—" %>
          </div>
          <div class="fb-table__cell fb-table__cell--outflow fb-table__cell--money <%= available < 0 ? 'fb-table__cell--negative' : (available > 0 ? 'fb-table__cell--positive' : '') %>">
            <%= number_to_currency(available, unit: "") %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
